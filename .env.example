# Valhalla Environment Variables
# Copy this file to .env and fill in the values

# Session secret - must be at least 32 characters long
SESSION_SECRET="change-this-to-a-very-long-random-secret-string-minimum-32-chars"

# Database URL (SQLite)
DATABASE_URL="file:./data/valhalla.db"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
